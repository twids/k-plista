# Example environment variables for docker-compose
# Copy this file to .env and update with your values

# Database configuration
POSTGRES_DB=kplista
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-database-password

# JWT configuration - IMPORTANT: Change these in production!
JWT_SECRET=your-secret-key-min-32-characters-long-for-security
JWT_ISSUER=kplista-api
JWT_AUDIENCE=kplista-app

# Optional: OAuth provider configuration
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET=your-facebook-app-secret

# Optional: Reverse proxy trusted network (CIDR) for X-Forwarded-Proto support.
# Required when running behind Traefik or another reverse proxy that terminates HTTPS.
# Set to the Docker bridge network CIDR to ensure OAuth redirect URIs use the correct scheme.
# Find the CIDR with: docker network inspect <network_name>
# REVERSE_PROXY_TRUSTED_NETWORK=172.16.0.0/12
